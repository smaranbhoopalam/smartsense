# ─── Serial Port ───────────────────────────────────────────
# Set to your ESP32's COM port (e.g., COM3, COM5, /dev/ttyUSB0)
# Leave empty for auto-detection
SERIAL_PORT=
SERIAL_BAUD=115200

# ─── Server ────────────────────────────────────────────────
PORT=3001
WS_PORT=3001

# ─── Telegram Notifications ───────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Security: Known MAC Addresses ────────────────────────
# Comma-separated list of trusted device MACs (uppercase, colon-separated)
KNOWN_MACS=AA:BB:CC:DD:EE:FF,11:22:33:44:55:66

# ─── Intrusion Detection Thresholds ───────────────────────
RSSI_STDDEV_THRESHOLD=5.0
RSSI_WINDOW_SIZE=20
